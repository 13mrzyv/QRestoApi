@inherits LayoutComponentBase

<div class="mobile-container">
    <div class="mobile-wrapper">
        @* Üst başlıq - Şəkildəki kimi loqo və ad hissəsi *@
        <div class="mobile-header">
            <div class="brand-section">
                <img src="images/logo.png" class="brand-logo" alt="Logo" />
                <div class="brand-info">
                    <span class="brand-name">Urban Bites</span>
                    <span class="brand-meta">Service fee: 15%</span>
                </div>
            </div>
        </div>

        @* Əsas məzmun sahəsi - Skrol olan hissə *@
        <div class="mobile-content">
            @Body
        </div>

        @* Alt Naviqasiya - NavMenu buradadır *@
        <div class="mobile-nav">
            <NavMenu />
        </div>

        @* iPhone-lardakı o kiçik alt xətt *@
        <div class="home-indicator"></div>
    </div>
</div>


<style>
    /* Səhifənin ümumi hündürlüyü */
    .page {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    /* Üst hissənin stili */
    .top-row {
        height: 3.5rem;
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    /* Məzmunun alt menyu ilə toqquşmaması üçün boşluq */
    .content {
        padding-bottom: 80px;
    }
</style>