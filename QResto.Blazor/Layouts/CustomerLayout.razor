@inherits LayoutComponentBase

<div class="phone-frame-container">
    <div class="phone-model">
        <div class="phone-screen">
            @Body
        </div>
        <div class="phone-home-bar"></div>
    </div>
</div>
<style>
    .phone-frame-container {
        background-color: #0d0d0d;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 0;
    }

    .phone-model {
        width: 325px;
        height: 612px;
        background: #000;
        border: 12px solid #222;
        border-radius: 45px;
        position: relative;
        overflow: hidden; /* İçindəki hər şeyi burada həbs edir */
        box-shadow: 0 0 50px rgba(0,0,0,0.8);
    }

    .phone-screen {
        position: relative;
        width: 100%;
        height: 100%;
        background-color: #000;
        overflow: hidden; /* Əsas ekran sürüşmür, yalnız daxilindəki məhsullar sürüşür */
    }

        /* Modalların çərçivəyə həbs edilməsi */
        .phone-screen .modal,
        .phone-screen .custom-modal-overlay {
            position: absolute !important;
            width: 100% !important;
            height: 100% !important;
            top: 0 !important;
            left: 0 !important;
            z-index: 1050;
        }

    .phone-home-bar {
        position: absolute;
        bottom: 8px;
        left: 50%;
        transform: translateX(-50%);
        width: 120px;
        height: 5px;
        background: rgba(255,255,255,0.2);
        border-radius: 10px;
        pointer-events: none;
        z-index: 1100;
    }
</style>