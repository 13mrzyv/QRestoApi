@inherits LayoutComponentBase

<div class="app-viewport">
    <main class="app-main-container">
        @Body
        <div class="mobile-home-indicator"></div>
    </main>
</div>

<style>
    /* Bütün səhifənin arxa fonu (Kompüter üçün) */
    .app-viewport {
        background-color: #0d0d0d;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 0;
    }

    /* Əsas konteyner - Sənin saytın buradadır */
    .app-main-container {
        position: relative;
        width: 100%;
        max-width: 480px; /* Kompüterdə maksimum bu qədər genişlənəcək */
        height: 100vh;
        background-color: #000;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 0 100px rgba(0,0,0,0.5);
    }

    /* @@media istifadə edərək Blazor-un C# xətası verməsinin qarşısını alırıq */
    @@media (max-width: 767px) {
        .app-main-container {
            max-width: 100%; /* Bütün ekranı tutsun */
            height: 100dvh; /* Mobil brauzerlər üçün dinamik hündürlük */
            border: none;
        }

        .app-viewport {
            background-color: #000; /* Boşluq qalmasın */
        }
    }

    .mobile-home-indicator {
        position: absolute;
        bottom: 8px;
        left: 50%;
        transform: translateX(-50%);
        width: 120px;
        height: 5px;
        background: rgba(255,255,255,0.15);
        border-radius: 10px;
        pointer-events: none;
        z-index: 2000;
    }
</style>