@inherits LayoutComponentBase

<div class="page">
    <main>
        @* Üst başlıq *@
        <div class="top-row px-4 shadow-sm d-flex align-items-center justify-content-center bg-white">
            <h5 class="m-0 fw-bold text-primary">Bizim Restoran</h5>
        </div>

        @* Əsas məzmun sahəsi *@
        <div class="content px-4 py-3">
            @Body
        </div>
    </main>

    @* Alt Naviqasiya *@
    <NavMenu />
</div>

<style>
    /* Səhifənin ümumi hündürlüyü */
    .page {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    /* Üst hissənin stili */
    .top-row {
        height: 3.5rem;
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    /* Məzmunun alt menyu ilə toqquşmaması üçün boşluq */
    .content {
        padding-bottom: 80px;
    }
</style>