@* @page "/" *@
@page "/admin/admindashboard"
@using Microsoft.AspNetCore.SignalR.Client
@using QResto.Blazor.Services
@using QResto.Shared.DTOs.Responses
@inject OrderService orderService
@layout QResto.Blazor.Layouts.AdminLayout
@inject NavigationManager NavManager



<div class="dashboard">

    <div class="dashboard-header">
        <h2 class="dashboard-title">İdarə Paneli Baxışı</h2>
        <div class="filter-wrapper">
            <div class="date-picker-container">
                <div class="date-input-group">
                    <span class="input-label">Başlanğıc:</span>
                    <div class="date-display-wrapper">
                        <input type="date" @bind="startDate" class="real-date-input" />
                        <div class="fake-date-input">@startDate.ToString("dd.MM.yyyy")</div>
                    </div>
                </div>

                <div class="date-input-group">
                    <span class="input-label">Bitmə:</span>
                    <div class="date-display-wrapper">
                        <input type="date" @bind="endDate" class="real-date-input" />
                        <div class="fake-date-input">@endDate.ToString("dd.MM.yyyy")</div>
                    </div>
                </div>

                <button class="filter-ok-btn" @onclick="@OnDateChanged">
                    <i class="fas fa-check"></i> OK
                </button>
            </div>
        </div>
    </div>

    <!-- Statistika Kartları -->
    <div class="stats-grid">

        <div class="stat-card daily-income-card">
            <div class="card-title-area">
                <span class="stat-label">Günlük Gəlir Analizi</span>
            </div>

            <div class="income-content">
                @if (totalSales == null)
                {
                    <div class="loading-state">
                        <i class="fas fa-circle-notch fa-spin"></i> Yüklənir...
                    </div>
                }
                else
                {
                    @* Ödənilmiş Hissəsi *@
                    <div class="income-group paid">
                        <div class="amount-wrapper">
                            <span class="amount-val">@totalSales.CompletedTotal.ToString("N2")</span>
                            <span class="currency">AZN</span>
                        </div>
                        <span class="group-label">ÖDƏNİLMİŞ</span>
                    </div>

                    <div class="income-divider"></div>

                    @* Aktiv Masa Hissəsi *@
                    <div class="income-group active">
                        <div class="amount-wrapper">
                            <span class="amount-val">@totalSales.ActiveTotal.ToString("N2")</span>
                            <span class="currency">AZN</span>
                        </div>
                        <span class="group-label">AKTİV MASA</span>
                    </div>
                }
            </div>
        </div>
        <div class="stats-column">
            <div class="stat-card" @onclick='() => NavManager.NavigateTo($"/waiter/waiterdashboard/{UserName}")' style="cursor:pointer;">
                <div class="stat-icon table-icon">🍽</div>
                <div class="stat-info">
                    <span class="stat-label">Masalar Ve Menyu</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon order-icon">👨‍🍳</div>
                <div class="stat-info">
                    <span class="stat-label">Aktiv Masalar</span>
                    <span class="stat-value">@numberOfActiveOrders</span>
                    @* <span class="stat-sub neutral">Mətbəx</span> *@
                </div>
            </div>
        </div>

    </div>

    <!-- Son Sifarişlər Cədvəli -->
    <div class="orders-card">
        <h3 class="card-title">Son Sifarişlər Cədvəli</h3>

        <div class="table-wrapper">
            <table class="orders-table">
                <thead>
                    <tr>
                        <th>Masa</th>
                        <th>Sifariş №</th>
                        <th>Saat</th>
                        <th>Cəmi</th>
                        <th>Status</th>
                        <th>Əməliyyat</th>
                    </tr>
                </thead>
                <tbody>
                    @if (orders == null)
                    {
                        <tr>
                            <td colspan="6" style="text-align:center;">Məlumatlar yüklənir...</td>
                        </tr>
                    }
                    else if (!orders.Any())
                    {
                        <tr>
                            <td colspan="6" style="text-align:center;">Bu gün üçün hələ ki sifariş yoxdur.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var order in orders)
                        {
                            <tr>
                                <td>@order.TableNumber</td>
                                <td>#@order.Id</td>
                                <td>@order.OrderDate.ToString("HH:mm")</td> @* Saat:Dəqiqə formatı *@
                                <td>@order.TotalAmount AZN</td>
                                <td>
                                    @* Statusa görə fərqli CSS class-ları veririk *@
                                    <span class="status-badge @GetStatusClass(order.Status)">
                                        @GetStatusText(order.Status)
                                    </span>
                                </td>
                                <td>
                                    <button class="btn-view" @onclick="() => ViewOrderDetails(order.Id)">
                                        Bax
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* _____________MODALS______________ *@
    @if (isOrderModalOpen && orderDetail != null)
    {
        <div class="admin-wrapper">
            <div class="modal-backdrop" @onclick="CloseModal">
                <div class="modal-content" @onclick:stopPropagation="true">

                    <div class="modal-header">
                        <div>
                            <h3>Sifariş #@orderDetail.OrderId (Masa @orderDetail.TableNumber)</h3>
                            @* Items siyahısındakı ilk məhsulun tarixini götürürük *@
                            <p class="modal-subtitle">
                                <i class="fa fa-clock"></i>
                                @(orderDetail.Items.FirstOrDefault()?.OrderDate.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </p>
                        </div>
                        <button class="close-btn" @onclick="CloseModal">&times;</button>
                    </div>

                    <div class="modal-body">
                        <table class="orders-table">
                            <thead>
                                <tr>
                                    <th>Saat</th> @* Yeni Sütun *@
                                    <th>Məhsul</th>
                                    <th>Say</th>
                                    <th>Qiymət</th>
                                    <th>Qeyd</th>
                                    <th>Cəmi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in orderDetail.Items)
                                {
                                    <tr>
                                        <td class="time-cell">
                                            <i class="fa fa-clock-o" style="font-size: 0.8rem; color: #999;"></i>
                                            @item.OrderDate.ToString("HH:mm")
                                        </td>
                                        <td>@item.ProductName</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.UnitPrice.ToString("N2") AZN</td>
                                        <td><small>@(item.Note ?? "-")</small></td>
                                        <td>@((item.UnitPrice * item.Quantity).ToString("N2")) AZN</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="modal-footer">
                        <div class="total-section">
                            Ümumi: @orderDetail.TotalAmount.ToString("N2") AZN
                        </div>
                        <button class="btn-view" @onclick="CloseModal">Bağla</button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@code {
    [Parameter] public string UserName { get; set; }
    private string SelectedPeriod { get; set; } = "week";
    private List<OrderSummaryResponse> orders;
    private int numberOfActiveOrders;
    private OrderDetailResponse orderDetail;
    private bool isOrderModalOpen = false;
    private TotalSalesResponse totalSales;
    private DateTime startDate = DateTime.Now;
    private DateTime endDate = DateTime.Now;
    private HubConnection? hubConnection;


    private async Task ViewOrderDetails(int orderId)
    {
        orderDetail = await orderService.GetOrderDetailsAsync(orderId);

        if (orderDetail != null)
        {
            // Artıq HTML-in içində deyil, metodun daxilindədir
            isOrderModalOpen = true;
        }
    }
    private void CloseModal()
    {
        isOrderModalOpen = false;
        orderDetail = null; // Yaddaşı təmizləyirik
    }

    protected override async Task OnInitializedAsync()
    {
        numberOfActiveOrders = await orderService.NumberOfActiveOrder();
        // 2. Dashboard datalarını (tarixə bağlı olanları) çəkirik
        await RefreshDashboard();

        // 3. SignalR Bağlantısını qururuq
        hubConnection = new HubConnectionBuilder()
            .WithUrl("https://localhost:7001/orderHub")
            .WithAutomaticReconnect()
            .Build();

        // 4. Serverdən "ReceiveOrderUpdate" siqnalı gələndə nə baş versin?
        hubConnection.On("ReceiveOrderUpdate", async () =>
        {
            await RefreshDashboard(); // Dataları yenidən çək
            StateHasChanged(); // UI-ı məcburi yenilə
        });

        await hubConnection.StartAsync();
    }
    // Tarix seçimi dəyişəndə çağırılacaq metod
    // Bu sənin mövcud məntiqini icra edən mərkəzi metodun olacaq
    private async Task RefreshDashboard()
    {
        orders = await orderService.GetOrdersByDateRangeAsync(startDate, endDate);
        totalSales = await orderService.GetTotalSalesAsync(startDate, endDate);
    }
    private async Task OnDateChanged()
    {
        await RefreshDashboard();
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    // Statusun rəngini müəyyən edən köməkçi metod
    private string GetStatusClass(int status) => status switch
    {
        1 => "status-preparing", // Yeni/Hazırlanır
        2 => "status-paid",      // Ödənildi
        _ => "status-default"
    };
    // Statusun mətnini qaytaran metod
    private string GetStatusText(int status) => status switch
    {
        1 => "Hazırlanır",
        2 => "Ödənildi",
        _ => "Məlum deyil"
    };



    private record OrderRow(string Table, string OrderId, string Customer, int Total, string Status);
}