@* _____________MODALS______________ *@
@if (isOrderModalOpen && orderDetail != null)
{
    <div class="admin-wrapper">
        <div class="modal-backdrop" @onclick="CloseModal">
            <div class="modal-content" @onclick:stopPropagation="true">

                <div class="modal-header">
                    <div>
                        <h3>SifariŇü #@orderDetail.OrderId (Masa @orderDetail.TableNumber)</h3>
                        @* Items siyahńĪsńĪndakńĪ ilk m…ôhsulun tarixini g√∂t√ľr√ľr√ľk *@
                        <p class="modal-subtitle">
                            <i class="fa fa-clock"></i>
                            @(orderDetail.Items.FirstOrDefault()?.OrderDate.ToString("dd.MM.yyyy HH:mm") ?? "-")
                        </p>
                    </div>
                    <button class="close-btn" @onclick="CloseModal">&times;</button>
                </div>

                <div class="modal-body">
                    <table class="orders-table">
                        <thead>
                            <tr>
                                <th>Saat</th> @* Yeni S√ľtun *@
                                <th>M…ôhsul</th>
                                <th>Say</th>
                                <th>Qiym…ôt</th>
                                <th>Qeyd</th>
                                <th>C…ômi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in orderDetail.Items)
                            {
                                <tr>
                                    <td class="time-cell">
                                        <i class="fa fa-clock-o" style="font-size: 0.8rem; color: #999;"></i>
                                        @item.OrderDate.ToString("HH:mm")
                                    </td>
                                    <td>@item.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.UnitPrice.ToString("N2") AZN</td>
                                    <td><small>@(item.Note ?? "-")</small></td>
                                    <td>@((item.UnitPrice * item.Quantity).ToString("N2")) AZN</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="modal-footer">
                    <div class="total-section">
                        √úmumi: @orderDetail.TotalAmount.ToString("N2") AZN
                    </div>
                    <button class="btn-view" @onclick="CloseModal">Bańüla</button>
                </div>
            </div>
        </div>
    </div>
}

@if (isExpenseModalOpen)
{
    <div class="modal-backdrop" @onclick="CloseExpenseModal">
        <div class="modal-content expanded-modal" @onclick:stopPropagation>

            <div class="modal-header">
                <h3>Bug√ľnk√ľ X…ôrcl…ôrin ńįdar…ô Edilm…ôsi</h3>
                <button class="close-btn" @onclick="CloseExpenseModal">&times;</button>
            </div>

            <div class="modal-body">

                <div class="table-wrapper">
                    <table class="expense-table">
                        <thead>
                            <tr>
                                <th style="width: 40px; text-align: center;">Sil</th>
                                <th>A√ßńĪqlama</th>
                                <th>M…ôbl…ôńü</th>
                                <th>Data</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (todayExpenses != null && todayExpenses.Any())
                            {
                                @foreach (var item in todayExpenses)
                                {
                                    <tr>
                                        <td style="text-align: center; vertical-align: middle;">
                                            <button class="delete-expense-btn"
                                                    @onclick="() => HandleDeleteExpense(item.Id)"
                                                    title="Sil">
                                                &times;
                                            </button>
                                        </td>
                                        <td>@item.Description</td>
                                        <td class="amt">@item.Amount.ToString("N2") AZN</td>
                                        <td class="time-col">@item.ExpenseDate.ToString("HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" style="text-align: center; color: #94a3b8; padding: 20px;">
                                        Bug√ľn √ľ√ß√ľn h…ôl…ô ki he√ß bir x…ôrc daxil edilm…ôyib.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="form-area">
                    <input type="text"
                           class="form-input"
                           placeholder="A√ßńĪqlama:"
                           @bind="expenseDescription"
                           @bind:event="oninput" />

                    <input type="number"
                           class="form-input"
                           placeholder="M…ôbl…ôńü"
                           @bind="expenseAmount"
                           @bind:event="oninput" />

                    <button class="submit-btn" @onclick="HandleAddExpense">
                        ∆Źlav…ô Et
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@if (showToast)
{
    <div class="toast-notification @(toastType == "danger" ? "toast-danger" : "")">
        <span class="toast-icon">@(toastType == "danger" ? "‚úē" : "‚úď")</span>
        <div class="toast-body">
            <span class="toast-title">@toastTitle</span>
            <span class="toast-desc">@toastDesc</span>
        </div>
    </div>
}

@code {
    [Parameter] public string UserName { get; set; }
    private string SelectedPeriod { get; set; } = "week";
    private List<OrderSummaryResponse> orders;
    private int numberOfActiveOrders;
    private OrderDetailResponse orderDetail;
    private bool isOrderModalOpen = false;
    private TotalSalesResponse totalSales;
    private DateTime startDate = DateTime.Now;
    private DateTime endDate = DateTime.Now;
    private HubConnection? hubConnection;

    // Finance

    private bool showToast = false;
    private string toastType = "success"; // "success" v…ô ya "danger"
    private string toastTitle = "";
    private string toastDesc = "";

    private string expenseDescription = "";
    private decimal expenseAmount = 0;

    private List<ExpenseResponse>? todayExpenses;

    private bool isExpenseModalOpen = false;

    //Finance


    private async Task ViewOrderDetails(int orderId)
    {
        orderDetail = await orderService.GetOrderDetailsAsync(orderId);

        if (orderDetail != null)
        {
            // ArtńĪq HTML-in i√ßind…ô deyil, metodun daxilind…ôdir
            isOrderModalOpen = true;
        }
    }
    private void CloseModal()
    {
        isOrderModalOpen = false;
        orderDetail = null; // YaddaŇüńĪ t…ômizl…ôyirik
    }

    protected override async Task OnInitializedAsync()
    {
        numberOfActiveOrders = await orderService.NumberOfActiveOrder();
        // 2. Dashboard datalarńĪnńĪ (tarix…ô bańülńĪ olanlarńĪ) √ß…ôkirik
        await RefreshDashboard();

        // 3. SignalR BańülantńĪsńĪnńĪ qururuq
        hubConnection = new HubConnectionBuilder()
            .WithUrl("https://localhost:7001/orderHub")
            .WithAutomaticReconnect()
            .Build();

        // 4. Serverd…ôn "ReceiveOrderUpdate" siqnalńĪ g…ôl…ônd…ô n…ô baŇü versin?
        hubConnection.On("ReceiveOrderUpdate", async () =>
        {
            await RefreshDashboard(); // DatalarńĪ yenid…ôn √ß…ôk
            StateHasChanged(); // UI-ńĪ m…ôcburi yenil…ô
        });

        await hubConnection.StartAsync();
    }
    // Tarix se√ßimi d…ôyiŇü…ônd…ô √ßańüńĪrńĪlacaq metod
    // Bu s…ônin m√∂vcud m…ôntiqini icra ed…ôn m…ôrk…ôzi metodun olacaq
    private async Task RefreshDashboard()
    {
        orders = await orderService.GetOrdersByDateRangeAsync(startDate, endDate);
        totalSales = await orderService.GetTotalSalesAsync(startDate, endDate);
    }
    private async Task OnDateChanged()
    {
        await RefreshDashboard();
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    // Statusun r…ôngini m√ľ…ôyy…ôn ed…ôn k√∂m…ôk√ßi metod
    private string GetStatusClass(int status) => status switch
    {
        1 => "status-preparing", // Yeni/HazńĪrlanńĪr
        2 => "status-paid",      // √Ėd…ônildi
        _ => "status-default"
    };
    // Statusun m…ôtnini qaytaran metod
    private string GetStatusText(int status) => status switch
    {
        1 => "HazńĪrlanńĪr",
        2 => "√Ėd…ônildi",
        _ => "M…ôlum deyil"
    };



    private record OrderRow(string Table, string OrderId, string Customer, int Total, string Status);

    // Finance
    // Finance
    // Finance

    private async Task OpenExpenseModal()
    {
        isExpenseModalOpen = true;
        // Modal a√ßńĪlanda …ôn son x…ôrcl…ôri backend-d…ôn √ß…ôkirik
        await LoadTodayExpenses();
    }
    private void CloseExpenseModal()
    {
        isExpenseModalOpen = false;
    }

    private async Task HandleAddSuccess()
    {
        toastType = "success";
        toastTitle = "Uńüurlu!";
        toastDesc = "X…ôrc uńüurla qeyd…ô alńĪndńĪ.";
        await TriggerToast();
    }

    // X…ôrc silin…ônd…ô √ßańüńĪrńĪlacaq metod
    private async Task HandleDeleteSuccess()
    {
        toastType = "danger";
        toastTitle = "Silindi!";
        toastDesc = "X…ôrc siyahńĪdan silindi.";
        await TriggerToast();
    }

    private async Task TriggerToast()
    {
        showToast = true;
        StateHasChanged(); // Blazor-a ekranńĪ yenil…ôm…ôsini deyirik

        // 3 saniy…ô (3000 millisaniy…ô) g√∂zl…ôyirik
        await Task.Delay(3000);

        showToast = false;
        StateHasChanged(); // BildiriŇüi ekrandan silirik
    }

    private async Task LoadTodayExpenses()
    {
        try
        {
            // Endpoint yolunu √∂z layih…ônd…ôki API strukturuna g√∂r…ô t…ônziml…ôy…ô bil…ôrs…ôn
            var result = await financeService.GetTodayExpensesAsync();
            if (result != null)
            {
                todayExpenses = result;
            }
        }
        catch (Exception ex)
        {
            // X…ôta baŇü ver…ôrs…ô konsola yazdńĪrńĪrńĪq, real layih…ôd…ô bir bildiriŇü mexanizmi qura bil…ôrik
            Console.WriteLine($"X…ôrc y√ľkl…ôn…ôrk…ôn x…ôta: {ex.Message}");
        }
    }

    private async Task HandleDeleteExpense(int id)
    {
        // API-…ô DELETE sorńüusunun g√∂nd…ôrilm…ôsi
        // var response = await Http.DeleteAsync($"api/expenses/{id
        var response = await financeService.DeleteExpenseAsync(id);

        if (response)
        {
            // Silinm…ô uńüurlu olarsa, siyahńĪnńĪ lokal olaraq yenil…ôyirik
            var itemToRemove = todayExpenses.FirstOrDefault(e => e.Id == id);
            if (itemToRemove != null)
            {
                todayExpenses.Remove(itemToRemove);
                StateHasChanged(); // Komponenti yenid…ôn render etm…ôk √ľ√ß√ľn
            }
        }
        else
        {
            // X…ôta baŇü ver…ôrs…ô konsola yazdńĪr v…ô ya istifad…ô√ßiy…ô bildir
            Console.WriteLine("X…ôrc silin…ôrk…ôn x…ôta baŇü verdi.");
        }

        await HandleDeleteSuccess();
    }


    private async Task HandleAddExpense()
    {
        // D…ôyiŇü…ônl…ôrin boŇü olub-olmadńĪńüńĪnńĪ yoxlayńĪrńĪq
        if (string.IsNullOrWhiteSpace(expenseDescription) || expenseAmount <= 0)
            return;

        // Request modelimizi qururuq (Biz bazada v…ô DTO-da 'Title' qoymuŇüduq)
        var dto = new CreateExpenseRequest
        {
            Description = expenseDescription,
            Amount = expenseAmount
        };

        // Servis…ô t…ôk parametr yox, b√ľt√∂v DTO obyektini g√∂nd…ôririk
        await financeService.AddExpenseAsync(dto);

        // Formu sńĪfńĪrlayńĪrńĪq
        expenseDescription = "";
        expenseAmount = 0;

        // SiyahńĪnńĪ anńĪnda yenil…ôyirik
        await LoadTodayExpenses();

        await HandleAddSuccess();
    }
    // Finance
    // Finance
    // Finance
}